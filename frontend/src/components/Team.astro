---
const metrics = [
  { h: 'Reach & engagement', p: 'Views, follows, and the posts pulling real attention, tracked across every platform.' },
  { h: 'Leads & conversations', p: 'The inbound, replies, and calls your content starts, tied back to what you posted.' },
  { h: 'AI answer visibility', p: 'Whether your name shows up when a buyer asks ChatGPT or Google\'s AI about your field.' },
];
---
<section id="about" style="padding-top:0">
  <div class="wrap">
    <div class="label reveal" data-cms-key="homepage_team_label">Who's behind your content</div>
    <h2 class="reveal d1" data-cms-key="homepage_team_title">You get a team, not a tool.</h2>
    <p class="support reveal d2" data-cms-key="homepage_team_sub">You show up for one hour a month. Here's who shows up for you.</p>

    <div class="team-grid">
      <div class="card team-profile reveal d2">
        <div class="profile-banner"></div>
        <div class="profile-body">
          <div class="profile-avatar">DW</div>
          <div class="profile-name" data-cms-key="homepage_team_name">Dennis Wakabayashi</div>
          <div class="profile-cred" data-cms-key="homepage_team_cred">Global Voice of CX · #1 CX Hall of Fame</div>
          <p class="profile-bio" data-cms-key="homepage_team_bio">
            Dennis has advised FedEx, McDonald's, AT&T, and Intuit on customer experience, co-authored Long Live CX,
            and hosts CX in the Wild. Your content clears the bar he sets for global brands.
          </p>
          <a class="profile-link" href="https://denniswakabayashi.com" target="_blank" rel="noopener">denniswakabayashi.com ↗</a>
        </div>
      </div>

      <div class="card team-stat reveal d3">
        <div class="stat-number" data-cms-key="homepage_team_stat_num">45</div>
        <div class="stat-label" data-cms-key="homepage_team_stat_label">humans behind your account</div>
        <p data-cms-key="homepage_team_stat_desc">
          An editor who learns your voice. Writers who draft in it. Designers who build your cards,
          strategists who plan your month, and reviewers who check every piece before you see it.
          Your subscription buys the bench, not a freelancer.
        </p>
      </div>
    </div>
  </div>
</section>

<section style="padding-top:0">
  <div class="wrap">
    <div class="label reveal" data-cms-key="homepage_metrics_label">Every month</div>
    <h2 class="reveal d1" data-cms-key="homepage_metrics_title">You'll see what's working.</h2>
    <div class="metrics-grid">

      <!-- Reach & engagement -->
      <div class="card metric-card reveal d2">
        <div class="metric-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="48" height="48" rx="14" fill="#C9A84C" fill-opacity="0.12"/>
            <path d="M10 34 L20 22 L27 29 L38 14" stroke="#C9A84C" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M31 14 H38 V21" stroke="#C9A84C" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="20" cy="22" r="2.5" fill="#C9A84C"/>
            <circle cx="27" cy="29" r="2.5" fill="#C9A84C"/>
            <circle cx="38" cy="14" r="2.5" fill="#C9A84C"/>
          </svg>
        </div>
        <h3 data-cms-key="homepage_metric1_title">Reach &amp; engagement</h3>
        <p data-cms-key="homepage_metric1_body">Views, follows, and the posts pulling real attention, tracked across every platform.</p>
      </div>

      <!-- Leads & conversations -->
      <div class="card metric-card reveal d3">
        <div class="metric-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="48" height="48" rx="14" fill="#C9A84C" fill-opacity="0.12"/>
            <path d="M14 16 H34 A3 3 0 0 1 37 19 V29 A3 3 0 0 1 34 32 H26 L20 37 V32 H14 A3 3 0 0 1 11 29 V19 A3 3 0 0 1 14 16 Z" stroke="#C9A84C" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="19" cy="24" r="1.8" fill="#C9A84C"/>
            <circle cx="24" cy="24" r="1.8" fill="#C9A84C"/>
            <circle cx="29" cy="24" r="1.8" fill="#C9A84C"/>
          </svg>
        </div>
        <h3 data-cms-key="homepage_metric2_title">Leads &amp; conversations</h3>
        <p data-cms-key="homepage_metric2_body">The inbound, replies, and calls your content starts, tied back to what you posted.</p>
      </div>

      <!-- AI answer visibility -->
      <div class="card metric-card reveal d4">
        <div class="metric-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="48" height="48" rx="14" fill="#C9A84C" fill-opacity="0.12"/>
            <!-- brain outline -->
            <path d="M24 12 C20 12 17 15 17 19 C14 19 12 21 12 24 C12 27 14 29 17 29 C17 31 18.5 33 20 34 L24 36 L28 34 C29.5 33 31 31 31 29 C34 29 36 27 36 24 C36 21 34 19 31 19 C31 15 28 12 24 12 Z" stroke="#C9A84C" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="24" y1="12" x2="24" y2="36" stroke="#C9A84C" stroke-width="2" stroke-dasharray="2 2.5"/>
            <!-- sparkle top-right -->
            <path d="M35 10 L36 13 L39 14 L36 15 L35 18 L34 15 L31 14 L34 13 Z" fill="#C9A84C"/>
          </svg>
        </div>
        <h3 data-cms-key="homepage_metric3_title">AI answer visibility</h3>
        <p data-cms-key="homepage_metric3_body">Whether your name shows up when a buyer asks ChatGPT or Google's AI about your field.</p>
      </div>

    </div>
  </div>
</section>

<style>
.team-grid {
  display: grid;
  grid-template-columns: 1.05fr .95fr;
  gap: 20px;
  margin-top: 36px;
  align-items: stretch;
}
.profile-banner {
  height: 80px;
  background: linear-gradient(120deg, var(--navy), #2A3053 60%, var(--gold));
  border-radius: var(--r) var(--r) 0 0;
}
.profile-body {
  padding: 0 24px 28px;
  position: relative;
}
.profile-avatar {
  width: 76px; height: 76px;
  border-radius: 50%;
  border: 4px solid var(--white);
  background: var(--navy);
  color: var(--gold);
  font-weight: 800;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -38px;
}
.profile-name {
  font-weight: 800;
  font-size: clamp(1.2rem, 3.5vw, 1.55rem);
  letter-spacing: -.02em;
  margin-top: 12px;
}
.profile-cred {
  font-weight: 700;
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--gold-dk);
  margin-top: 4px;
}
.profile-bio {
  color: var(--muted);
  font-size: .95rem;
  margin-top: 14px;
  line-height: 1.65;
}
.profile-link {
  display: inline-block;
  margin-top: 16px;
  font-weight: 700;
  font-size: .9rem;
  color: var(--gold-dk);
}
.profile-link:hover { text-decoration: underline; }

.team-stat {
  padding: 36px 32px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.stat-number {
  font-weight: 800;
  font-size: clamp(3.5rem, 8vw, 5rem);
  letter-spacing: -.04em;
  line-height: 1;
  color: var(--gold-dk);
}
.stat-label {
  font-weight: 700;
  font-size: 1.05rem;
  margin-top: 6px;
  margin-bottom: 16px;
}
.team-stat p { font-size: .95rem; line-height: 1.65; }

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-top: 36px;
}
.metric-card { padding: 28px 24px; }
.metric-icon {
  width: 52px;
  height: 52px;
  margin-bottom: 18px;
  flex-shrink: 0;
}
.metric-icon svg {
  width: 52px;
  height: 52px;
  display: block;
}
.metric-card h3 { color: var(--gold-dk); margin-bottom: 8px; }
.metric-card p { font-size: .92rem; }

@media (max-width: 860px) {
  .team-grid { grid-template-columns: 1fr; }
  .metrics-grid { grid-template-columns: 1fr; }
}
</style>
