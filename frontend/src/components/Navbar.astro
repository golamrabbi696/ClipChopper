---
const pathname = Astro.url.pathname;
const isBrandsPage = pathname === '/brands' || pathname === '/brands/';
const toggleLink = isBrandsPage ? '/' : '/brands/';
const toggleText = isBrandsPage ? 'For Personal' : 'For Brands';

// Anchor links dynamic mapping
const howLink = isBrandsPage ? '#how' : '/#how';
const pricingLink = isBrandsPage ? '#pricing' : '/#foryou';
const aboutLink = isBrandsPage ? '#about' : '/#about';
---
<header id="top">
  <div class="wrap navbar">
    <a class="logo" href="/" id="site-logo-link">
      <span class="logomark" id="site-logomark" aria-hidden="true">CC</span>
      <span class="logotype" id="site-logotype">CLIPCHOPPER</span>
    </a>
    <nav class="navlinks" aria-label="Main navigation">
      <a href={toggleLink}>{toggleText}</a>
      <a href={howLink}>How it works</a>
      <a href={pricingLink}>Pricing</a>
      <a href={aboutLink}>About</a>
    </nav>
    <a class="btn btn-primary navcta" href="/contact" id="nav-book-cta">Book a call</a>
    <button class="hamburger" id="hamburger-btn" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <a href={toggleLink}>{toggleText}</a>
    <a href={howLink}>How it works</a>
    <a href={pricingLink}>Pricing</a>
    <a href={aboutLink}>About</a>
    <a class="btn btn-primary" href="/contact">Book a call</a>
  </div>
</header>

<style>
header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(250,250,248,.90);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  transition: box-shadow .3s var(--ease);
}
header.scrolled { box-shadow: var(--shadow); }

.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
  gap: 24px;
}

.logo {
  display: flex;
  align-items: center;
  text-decoration: none;
  flex-shrink: 0;
}
.logo-img {
  height: 38px;
  width: auto;
  display: block;
  object-fit: contain;
}

.navlinks {
  display: flex;
  align-items: center;
  gap: 32px;
  margin: 0 auto;
}
.navlinks a {
  font-weight: 600;
  font-size: 14.5px;
  color: var(--muted);
  transition: color .18s var(--ease);
}
.navlinks a:hover { color: var(--ink); }

.navcta { min-height: 40px; padding: 0 20px; font-size: 14px; }

.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 36px;
  height: 36px;
  padding: 4px;
}
.hamburger span {
  display: block;
  height: 2px;
  background: var(--ink);
  border-radius: 2px;
  transition: transform .25s var(--ease), opacity .25s var(--ease);
}

.mobile-menu {
  display: none;
  flex-direction: column;
  gap: 4px;
  padding: 12px var(--pad) 20px;
  border-top: 1px solid var(--border);
  background: rgba(250,250,248,.97);
}
.mobile-menu a {
  font-weight: 600;
  font-size: 16px;
  color: var(--ink-2);
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
}
.mobile-menu .btn { margin-top: 10px; width: 100%; }

@media (max-width: 768px) {
  .navlinks { display: none; }
  .navcta { display: none; }
  .hamburger { display: flex; }
  .mobile-menu.open { display: flex; }
}
</style>

<script>
  const btn = document.getElementById('hamburger-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => {
    const open = menu.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
    menu.setAttribute('aria-hidden', String(!open));
  });
  window.addEventListener('scroll', () => {
    document.querySelector('header')!.classList.toggle('scrolled', window.scrollY > 8);
  }, { passive: true });

  // Dynamic Logo Loader
  (async () => {
    try {
      const res = await fetch('https://adopted-trout-informational-crowd.trycloudflare.com/api/v1/settings');
      if (res.ok) {
        const settings = await res.json();
        const logomark = document.getElementById('site-logomark');
        const logotype = document.getElementById('site-logotype');
        const logoLink = document.getElementById('site-logo-link');
        
        if (settings.logo_type === 'image' && settings.logo_image_url) {
          if (logoLink) {
            logoLink.innerHTML = `<img src="${settings.logo_image_url}" alt="${settings.logo_text_type || 'ClipChopper'}" style="height: 36px; max-width: 180px; object-fit: contain;" />`;
          }
        } else {
          if (logomark) logomark.textContent = settings.logo_text_mark || 'CC';
          if (logotype) logotype.textContent = settings.logo_text_type || 'CLIPCHOPPER';
        }
      }
    } catch (err) {
      console.error('Failed to load site branding settings', err);
    }
  })();
</script>
