---
const pathname = Astro.url.pathname;
const isBrandsPage = pathname.startsWith('/brands');
const toggleLink = isBrandsPage ? '/' : '/brands/';
const toggleText = isBrandsPage ? 'For Personal' : 'For Brands';

// Anchor links dynamic mapping
const howLink = isBrandsPage ? '/brands#how' : '/#how';
const pricingLink = isBrandsPage ? '/brands#pricing' : '/#foryou';
const aboutLink = isBrandsPage ? '/brands#about' : '/#about';
const contactLink = isBrandsPage ? '/brands/contact' : '/contact';
---
<footer>
  <div class="wrap footer-inner">
    <div class="footer-brand" id="site-footer-link">
      <img id="footer-logo-img" src="/images/logo.png" alt="ClipChopper" style="height:28px;max-width:140px;object-fit:contain;display:block;" />
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href={toggleLink}>{toggleText}</a>
      <a href={howLink}>How it works</a>
      <a href={pricingLink}>Pricing</a>
      <a href={aboutLink}>About</a>
      <a href={contactLink}>Contact</a>
    </nav>
    <div class="footer-copy">
      <span>clipchopper.com</span>
      <span>·</span>
      <span>© 2026 ClipChopper</span>
    </div>
  </div>
</footer>

<style>
footer {
  border-top: 1px solid var(--border);
  background: var(--white);
  padding: 28px 0;
}
.footer-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 16px 32px;
  align-items: center;
  justify-content: space-between;
}
.footer-brand {
  display: flex;
  align-items: center;
  gap: 8px;
}
.footer-logo-img {
  height: 28px;
  width: auto;
  display: block;
  object-fit: contain;
}
.footer-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
}
.footer-nav a {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--muted);
  transition: color .18s;
}
.footer-nav a:hover { color: var(--ink); }
.footer-copy {
  display: flex;
  gap: 8px;
  font-size: 13px;
  color: var(--faint);
}
@media (max-width: 640px) {
  .footer-inner { flex-direction: column; align-items: flex-start; gap: 16px; }
  .footer-nav { gap: 12px; }
}
</style>

<script>
  // Footer logo: swap src from localStorage on load (no flash)
  const LOGO_CACHE_KEY = 'cc_logo_settings';
  try {
    const cached = localStorage.getItem(LOGO_CACHE_KEY);
    if (cached) {
      const { data } = JSON.parse(cached);
      const img = document.getElementById('footer-logo-img') as HTMLImageElement;
      if (img && data?.logo_image_url) {
        img.src = data.logo_image_url;
        if (data.logo_text_type) img.alt = data.logo_text_type;
      }
    }
  } catch {}

  // When admin saves branding, update src
  window.addEventListener('cc-logo-updated', async () => {
    const API_BASE = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? 'http://127.0.0.1:8000'
      : 'https://api.clipchopper.com';
    try {
      const res = await fetch(`${API_BASE}/api/v1/settings`, { cache: 'no-store' });
      if (!res.ok) return;
      const settings = await res.json();
      localStorage.setItem(LOGO_CACHE_KEY, JSON.stringify({ ts: Date.now(), data: settings }));
      const img = document.getElementById('footer-logo-img') as HTMLImageElement;
      if (img && settings.logo_image_url) {
        img.src = settings.logo_image_url;
        img.alt = settings.logo_text_type || 'ClipChopper';
      }
    } catch {}
  });
</script>
