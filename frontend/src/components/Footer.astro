---
import { Image } from 'astro:assets';
import logo from '../assets/logo/ClipChopper_Logo.png';
---
<footer>
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <Image src={logo} alt="ClipChopper" class="footer-logo-img" />
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/#how">How it works</a>
      <a href="/#foryou">Pricing</a>
      <a href="/#about">About</a>
      <a href="/contact">Contact</a>
      <a href="/brands/">For brands</a>
    </nav>
    <div class="footer-copy">
      <span>clipchopper.com</span>
      <span>·</span>
      <span>© 2026 ClipChopper</span>
    </div>
  </div>
</footer>

<style>
footer {
  border-top: 1px solid var(--border);
  background: var(--white);
  padding: 28px 0;
}
.footer-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 16px 32px;
  align-items: center;
  justify-content: space-between;
}
.footer-brand {
  display: flex;
  align-items: center;
  gap: 8px;
}
.footer-logo-img {
  height: 28px;
  width: auto;
  display: block;
  object-fit: contain;
}
.footer-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
}
.footer-nav a {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--muted);
  transition: color .18s;
}
.footer-nav a:hover { color: var(--ink); }
.footer-copy {
  display: flex;
  gap: 8px;
  font-size: 13px;
  color: var(--faint);
}
@media (max-width: 640px) {
  .footer-inner { flex-direction: column; align-items: flex-start; gap: 16px; }
  .footer-nav { gap: 12px; }
}
</style>
