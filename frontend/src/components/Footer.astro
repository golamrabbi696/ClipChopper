---
const pathname = Astro.url.pathname;
const isBrandsPage = pathname === '/brands' || pathname === '/brands/';
const toggleLink = isBrandsPage ? '/' : '/brands/';
const toggleText = isBrandsPage ? 'For Personal' : 'For Brands';

// Anchor links dynamic mapping
const howLink = isBrandsPage ? '#how' : '/#how';
const pricingLink = isBrandsPage ? '#pricing' : '/#foryou';
const aboutLink = isBrandsPage ? '#about' : '/#about';
---
<footer>
  <div class="wrap footer-inner">
    <div class="footer-brand" id="site-footer-link">
      <div class="f-logomark" id="footer-logomark" aria-hidden="true">CC</div>
      <span class="f-logotype" id="footer-logotype">CLIPCHOPPER</span>
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href={toggleLink}>{toggleText}</a>
      <a href={howLink}>How it works</a>
      <a href={pricingLink}>Pricing</a>
      <a href={aboutLink}>About</a>
      <a href="/contact">Contact</a>
    </nav>
    <div class="footer-copy">
      <span>clipchopper.com</span>
      <span>·</span>
      <span>© 2026 ClipChopper</span>
    </div>
  </div>
</footer>

<style>
footer {
  border-top: 1px solid var(--border);
  background: var(--white);
  padding: 28px 0;
}
.footer-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 16px 32px;
  align-items: center;
  justify-content: space-between;
}
.footer-brand {
  display: flex;
  align-items: center;
  gap: 8px;
}
.f-logomark {
  width: 28px; height: 28px;
  border-radius: 7px;
  background: var(--navy);
  color: var(--gold);
  font-weight: 800;
  font-size: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.f-logotype {
  font-weight: 800;
  font-size: 12px;
  letter-spacing: .18em;
  color: var(--ink);
}
.footer-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
}
.footer-nav a {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--muted);
  transition: color .18s;
}
.footer-nav a:hover { color: var(--ink); }
.footer-copy {
  display: flex;
  gap: 8px;
  font-size: 13px;
  color: var(--faint);
}
@media (max-width: 640px) {
  .footer-inner { flex-direction: column; align-items: flex-start; gap: 16px; }
  .footer-nav { gap: 12px; }
}
</style>

<script>
  // Dynamic Footer Logo Loader
  (async () => {
    try {
      const res = await fetch('http://localhost:8000/api/v1/settings');
      if (res.ok) {
        const settings = await res.json();
        const logomark = document.getElementById('footer-logomark');
        const logotype = document.getElementById('footer-logotype');
        const brandLink = document.getElementById('site-footer-link');
        
        if (settings.logo_type === 'image' && settings.logo_image_url) {
          if (brandLink) {
            brandLink.innerHTML = `<img src="${settings.logo_image_url}" alt="${settings.logo_text_type || 'ClipChopper'}" style="height: 28px; max-width: 140px; object-fit: contain;" />`;
          }
        } else {
          if (logomark) logomark.textContent = settings.logo_text_mark || 'CC';
          if (logotype) logotype.textContent = settings.logo_text_type || 'CLIPCHOPPER';
        }
      }
    } catch (err) {
      console.error('Failed to load footer branding settings', err);
    }
  })();
</script>
