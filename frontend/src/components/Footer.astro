---
---
<footer>
  <div class="wrap footer-inner">
    <div class="footer-brand">
      <div class="f-logomark" aria-hidden="true">CC</div>
      <span class="f-logotype">CLIPCHOPPER</span>
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/#how">How it works</a>
      <a href="/#foryou">Pricing</a>
      <a href="/#about">About</a>
      <a href="/contact">Contact</a>
      <a href="/brands/">For brands</a>
    </nav>
    <div class="footer-copy">
      <span>clipchopper.com</span>
      <span>·</span>
      <span>© 2026 ClipChopper</span>
    </div>
  </div>
</footer>

<style>
footer {
  border-top: 1px solid var(--border);
  background: var(--white);
  padding: 28px 0;
}
.footer-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 16px 32px;
  align-items: center;
  justify-content: space-between;
}
.footer-brand {
  display: flex;
  align-items: center;
  gap: 8px;
}
.f-logomark {
  width: 28px; height: 28px;
  border-radius: 7px;
  background: var(--navy);
  color: var(--gold);
  font-weight: 800;
  font-size: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.f-logotype {
  font-weight: 800;
  font-size: 12px;
  letter-spacing: .18em;
  color: var(--ink);
}
.footer-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
}
.footer-nav a {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--muted);
  transition: color .18s;
}
.footer-nav a:hover { color: var(--ink); }
.footer-copy {
  display: flex;
  gap: 8px;
  font-size: 13px;
  color: var(--faint);
}
@media (max-width: 640px) {
  .footer-inner { flex-direction: column; align-items: flex-start; gap: 16px; }
  .footer-nav { gap: 12px; }
}
</style>
