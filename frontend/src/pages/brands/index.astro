---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="ClipChopper for Brands: One asset. A month of content." description="Your webinars, demos, and exec talks become 72 pieces of on-brand content: 16 videos, 16 posts, and 40 quote cards, checked by a person before anything ships.">
  <Navbar />
  <main>
    <!-- HERO -->
    <section class="hero" id="top">
      <div class="wrap hero-inner">
        <div class="hero-text">
          <div class="label reveal">Always on. Always on brand.</div>
          <h1 class="reveal d1">Always on.<br /><span class="coral-text">Always on brand.</span></h1>
          <p class="hero-sub reveal d2">
            One asset in. <b>72 pieces</b> out. Your webinars, demos, and exec talks become a feed that never goes quiet: cut, written, designed, and checked by a person before anything ships.
          </p>
          <div class="ctas reveal d3">
            <a class="btn btn-coral" href="#book">Book a call</a>
            <a class="btn btn-ghost" href="#pricing">See pricing</a>
          </div>
          <div class="social-proof reveal d4">
            <div class="avatars" aria-hidden="true">
              <span class="sp-avatar" style="background:#E86F50; color:var(--navy);">DW</span>
              <span class="sp-avatar" style="background:#2A3053; color:var(--coral);">CO</span>
              <span class="sp-avatar" style="background:#1E2440; color:var(--coral);">CC</span>
            </div>
            <p class="sp-text">Joined by <strong>45 humans</strong> who show up for you every month</p>
          </div>
        </div>

        <div class="hero-feed reveal d2" aria-label="Examples of the posts we make for your brand">
          <div class="feed-label">Your brand, in the feed</div>

          <article class="card feed-post">
            <div class="post-head">
              <span class="post-avatar">CO</span>
              <div class="post-meta">
                <strong>Your Company</strong>
                <span>12,400 followers &middot; 1d</span>
              </div>
            </div>
            <p class="post-text">From last month's product webinar: the part most teams miss.</p>
            <div class="post-media video-thumb" aria-label="Short video clip">
              <span class="play-btn" aria-hidden="true"></span>
              <span class="video-caption">"Here's where the real cost hides."</span>
            </div>
            <div class="post-foot">
              <span class="reactions"><span class="react">👍</span><span class="react">💡</span> Your buyers</span>
              <span>Comments &middot; Reposts</span>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- THE WANT -->
    <section class="want" id="want">
      <div class="wrap want-feed-wrap">
        <div class="want-feed reveal d2" aria-label="Example quote card">
          <article class="card feed-post">
            <div class="post-head">
              <span class="post-avatar">CO</span>
              <div class="post-meta">
                <strong>Your Company</strong>
                <span>12,400 followers &middot; 4d</span>
              </div>
            </div>
            <div class="post-media quote-card">
              <p class="quote-text">"Great products don't explain themselves. Great content does."</p>
              <span class="quote-attr">YOUR COMPANY &middot; in your brand kit</span>
            </div>
            <div class="post-foot">
              <span class="reactions"><span class="react">👍</span><span class="react">❤️</span> The right people</span>
              <span>Saved &middot; Shared</span>
            </div>
          </article>
        </div>
      </div>

      <div class="wrap want-inner">
        <h2 class="reveal">Your buyers scroll every day.</h2>
        <p class="support reveal d1">
          Your brand shows up when there's a launch. In between, the feed belongs to whoever keeps posting.
        </p>
      </div>
    </section>

    <!-- THE COST -->
    <section class="cost-section" style="padding-top:0">
      <div class="wrap">
        <h2 class="reveal">Staying visible shouldn't need a new budget line.</h2>
        <div class="cost-grid">
          <div class="cost-card card reveal d1">
            <div class="cost-who">Hiring an agency</div>
            <div class="cost-big">$3,000–$25,000</div>
            <div class="cost-unit">a month, before you've shipped a single post</div>
          </div>
          <div class="vs-badge reveal d2">vs</div>
          <div class="cost-card card reveal d3">
            <div class="cost-who">Building in-house</div>
            <div class="cost-big">3 hires</div>
            <div class="cost-unit">an editor, a designer, and a writer, before benefits</div>
          </div>
        </div>
        <p class="better-way reveal d4">There’s a better way: the webinars, demos, and talks you already have. ↓</p>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section id="how" style="padding-top:0">
      <div class="wrap">
        <div class="label reveal">How it works</div>
        <h2 class="reveal d1">One asset. We do everything up to publish.</h2>
        <p class="support reveal d2">
          No shoots, no scripts, no production budget. The footage already exists, and the finish matches the biggest names on TikTok, LinkedIn, and YouTube.
        </p>

        <div class="steps-timeline">
          <div class="step-item reveal d1">
            <div class="step-connector" aria-hidden="true">
              <div class="step-dot">1</div>
              <div class="step-line"></div>
            </div>
            <div class="card step-card">
              <h3>Pick an asset</h3>
              <p>A webinar, a demo, an exec talk. Or book a podcast-style interview with your founder.</p>
            </div>
          </div>
          <div class="step-item reveal d2">
            <div class="step-connector" aria-hidden="true">
              <div class="step-dot">2</div>
              <div class="step-line"></div>
            </div>
            <div class="card step-card">
              <h3>We cut the month</h3>
              <p>Best moments into clips, posts written, cards designed, all in your brand voice.</p>
            </div>
          </div>
          <div class="step-item reveal d3">
            <div class="step-connector" aria-hidden="true">
              <div class="step-dot">3</div>
              <div class="step-line"></div>
            </div>
            <div class="card step-card">
              <h3>Checked by a person</h3>
              <p>Every piece passes a human brand-safety review: claims, tone, guidelines.</p>
            </div>
          </div>
          <div class="step-item reveal d4">
            <div class="step-connector" aria-hidden="true">
              <div class="step-dot">4</div>
              <div class="step-line"></div>
            </div>
            <div class="card step-card">
              <h3>Your team approves</h3>
              <p>Nothing ships until you sign off.</p>
            </div>
          </div>
          <div class="step-item reveal d5">
            <div class="step-connector" aria-hidden="true">
              <div class="step-dot">5</div>
            </div>
            <div class="card step-card">
              <h3>You post it</h3>
              <p>Everything arrives on a calendar, formatted for every channel. Your team publishes.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="navy-band">
      <div class="wrap">
        <div class="label reveal" style="color:var(--coral)">What one asset becomes</div>
        <h2 class="reveal d1" style="color:var(--cream)">A full month of content, every month.</h2>
        <div class="get-grid">
          <ul class="get-list reveal d2">
            <li><strong>16 short videos</strong>, cut from one webinar, demo, or talk</li>
            <li><strong>16 written posts</strong>, the words to run with each video</li>
            <li><strong>40 quote cards</strong>, your sharpest lines, in your brand kit</li>
            <li><strong>Ready to publish</strong>, approved and laid out on a calendar</li>
            <li><strong>Monthly measurement</strong>, what moved and what to run next</li>
          </ul>
          <div class="get-aside reveal d3">
            <div class="aside-big">72 pieces of content from <span style="color:var(--coral)">one asset.</span></div>
            <p>Enough to show up every day of the month, on every channel your buyers scroll.</p>
            <div class="platform-chips">
              <span>LinkedIn</span><span>Instagram</span><span>YouTube</span><span>TikTok</span><span>X</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BRAND SAFETY -->
    <section>
      <div class="wrap">
        <div class="label reveal">What stays yours</div>
        <h2 class="reveal d1">Protect the brand.</h2>
        <p class="support reveal d2">
          On voice. On message. Approved by your team. Filling the feed shouldn't mean gambling the logo on it.
        </p>
        <div class="pillar-grid">
          <div class="card pillar pillar-mark reveal d2">
            <div class="pillar-icon" aria-hidden="true">✦</div>
            <h3>Your guidelines come first</h3>
            <p>Before anything gets cut, we learn the brand voice, the claims rules, and the no-go list.</p>
          </div>
          <div class="card pillar reveal d3">
            <div class="pillar-icon" aria-hidden="true">◈</div>
            <h3>A person checks every piece</h3>
            <p>Nothing automated ships itself. A human reviews each clip, post, and card against your standards.</p>
          </div>
          <div class="card pillar reveal d4">
            <div class="pillar-icon" aria-hidden="true">◉</div>
            <h3>Original, from your material</h3>
            <p>Every piece is cut from content your company already made. Nothing templated, nothing recycled, nothing pulled from thin air.</p>
          </div>
        </div>
        <p class="tools-note reveal d5">
          Modern tools handle the tedious parts backstage, so your budget goes to the craft, not the busywork.
        </p>
      </div>
    </section>

    <!-- PRICING -->
    <section id="pricing" style="padding-top:0">
      <div class="wrap">
        <div class="card profile reveal">
          <div class="banner"></div>
          <div class="pbody">
            <div class="pavatar">CO</div>
            <div class="pname">For <em>your brand</em></div>
            <p class="psub">Marketing teams with a library of webinars, demos, and exec talks. We turn what you already have into a feed that never goes quiet.</p>
            
            <div class="pricing-grid">
              <!-- One-time -->
              <div class="card tier reveal d2">
                <div class="tier-kind">One-time</div>
                <div class="tier-name">Try it once</div>
                <div class="tier-price">$3,500</div>
                <ul class="tier-features">
                  <li>One asset becomes 16 videos + posts</li>
                  <li>40 branded quote cards</li>
                  <li>Brand-safety check on every piece</li>
                  <li>Formatted for every channel, ready to post</li>
                </ul>
                <a class="btn btn-ghost tier-btn" href="/brands/contact?plan=brands-one-time">Get started</a>
              </div>

              <!-- Subscribe -->
              <div class="card tier tier-featured reveal d3">
                <div class="tier-badge">Commit and save</div>
                <div class="tier-kind">Monthly subscription</div>
                <div class="tier-name">Subscribe</div>
                <div class="tier-price">$2,999<span class="tier-per">/mo</span></div>
                <ul class="tier-features">
                  <li>The same volume, every month</li>
                  <li>Brand-safety check on every piece</li>
                  <li>Monthly measurement reports</li>
                  <li>Cancel anytime, no contracts</li>
                </ul>
                <a class="btn btn-coral tier-btn" href="/brands/contact?plan=brands-monthly">Start monthly →</a>
              </div>
            </div>
            
            <p class="crosslink">Building a personal brand instead? <a href="/">ClipChopper for you →</a></p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHO IS BEHIND THIS -->
    <section id="about" style="padding-top:0">
      <div class="wrap">
        <div class="label reveal">Who's behind your content</div>
        <h2 class="reveal d1">You get a team, not a tool.</h2>
        <p class="support reveal d2">You send one asset a month. Here's who turns it into your feed.</p>
        
        <div class="team-grid">
          <div class="card team-profile reveal d2">
            <div class="profile-banner"></div>
            <div class="profile-body">
              <div class="profile-avatar">DW</div>
              <div class="profile-name">Dennis Wakabayashi</div>
              <div class="profile-cred">Global Voice of CX · #1 CX Hall of Fame</div>
              <p class="profile-bio">
                Customer experience is the discipline of earning trust. Dennis has advised FedEx, McDonald's, AT&amp;T, and Intuit on it, co-authored Long Live CX, hosts CX in the Wild, and is ranked number one in the world on the CX Hall of Fame. Your content clears the bar he sets for global brands.
              </p>
              <a class="profile-link" href="https://denniswakabayashi.com" target="_blank" rel="noopener">denniswakabayashi.com ↗</a>
            </div>
          </div>

          <div class="card team-stat reveal d3">
            <div class="stat-number">45</div>
            <div class="stat-label">humans behind your account</div>
            <p>
              An editor who learns your brand voice. Writers who draft in it. Designers who build to your kit, strategists who plan the month, and reviewers who check every piece against your guidelines before your team sees it. Your subscription buys the bench, not a freelancer.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- PROOF -->
    <section style="padding-top:0">
      <div class="wrap">
        <div class="label reveal">Every month</div>
        <h2 class="reveal d1">You'll see what's working.</h2>
        <div class="metrics-grid">
          <div class="card metric-card reveal d2">
            <div class="metric-icon" aria-hidden="true">📈</div>
            <h3>Reach &amp; engagement</h3>
            <p>Views, follows, and the posts pulling real attention, tracked across every platform.</p>
          </div>
          <div class="card metric-card reveal d3">
            <div class="metric-icon" aria-hidden="true">💬</div>
            <h3>Leads &amp; conversations</h3>
            <p>The inbound, replies, and calls your content starts, tied back to what you posted.</p>
          </div>
          <div class="card metric-card reveal d4">
            <div class="metric-icon" aria-hidden="true">🤖</div>
            <h3>AI answer visibility</h3>
            <p>Whether your brand shows up when a buyer asks ChatGPT or Google's AI about your space.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- BOOK -->
    <section class="book-cta" id="book">
      <div class="wrap book-inner">
        <div class="book-text">
          <h2 class="reveal" style="color:var(--cream)">Let's make your brand impossible to miss.</h2>
          <p class="support reveal d1" style="color:#B7BCD4">
            It starts with one asset. Send it over, and we hand back a month ready to post.
          </p>
          <div class="book-actions reveal d2">
            <a class="btn btn-coral" href="/brands/contact" id="book-main-cta">Book a call →</a>
          </div>
        </div>
        
        <div class="book-form card reveal d3">
          <div class="form-label">Or drop us a quick note</div>
          <form id="quick-contact-form" action="https://adopted-trout-informational-crowd.trycloudflare.com/api/v1/contact" method="POST" novalidate>
            <div class="field">
              <label for="qc-name">Your name</label>
              <input type="text" id="qc-name" name="name" placeholder="Jane Smith" required />
            </div>
            <div class="field">
              <label for="qc-email">Email address</label>
              <input type="email" id="qc-email" name="email" placeholder="jane@company.com" required />
            </div>
            <div class="field">
              <label for="qc-msg">What are you working on?</label>
              <textarea id="qc-msg" name="message" placeholder="Tell us a bit about yourself…" rows="3"></textarea>
            </div>
            <button class="btn btn-coral submit-btn" type="submit" id="qc-submit">Send message →</button>
            <p class="form-success" id="qc-success" aria-live="polite"></p>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  /* Specific styling overrides for brands page to match homepage style but with Coral theme */
  :root {
    --coral: #E86F50;
    --coral-dk: #C7532F;
  }
  
  .coral-text {
    color: var(--coral-dk);
  }
  
  .btn-coral {
    background: var(--coral) !important;
    color: var(--navy) !important;
    box-shadow: 0 2px 12px rgba(232, 111, 80, 0.25) !important;
    transition: transform .18s var(--ease), box-shadow .18s var(--ease), background .18s var(--ease) !important;
  }
  
  .btn-coral:hover {
    background: #ee8266 !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 4px 20px rgba(232, 111, 80, 0.35) !important;
  }
  .btn-coral:active {
    transform: translateY(0) !important;
  }

  /* Hero Section overrides */
  .hero {
    padding-top: clamp(48px, 7vw, 88px);
    padding-bottom: clamp(48px, 7vw, 88px);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 60% -10%, rgba(232, 111, 80, 0.08) 0%, transparent 70%) !important;
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr .9fr;
    gap: clamp(36px, 6vw, 72px);
    align-items: center;
  }
  .hero-sub {
    font-size: clamp(1rem, 2.4vw, 1.15rem);
    color: var(--muted);
    max-width: 46ch;
    margin-top: 18px;
    line-height: 1.7;
  }
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }
  .social-proof {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 28px;
    text-align: left;
  }
  .avatars { display: flex; }
  .sp-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 2px solid var(--white);
    font-weight: 800;
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: -8px;
  }
  .avatars .sp-avatar:first-child { margin-left: 0; }
  .sp-text { font-size: 13.5px; color: var(--muted); }
  .sp-text strong { color: var(--ink); }

  /* Feed */
  .hero-feed { display: flex; flex-direction: column; gap: 16px; }
  .feed-label {
    font-weight: 700;
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--faint);
    margin-bottom: 4px;
    text-align: left;
  }
  .feed-post { padding: 18px; text-align: left; }
  .post-head { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .post-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    font-weight: 800;
    font-size: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--coral) !important;
    background: var(--navy) !important;
  }
  .post-meta strong { display: block; font-size: 14px; }
  .post-meta span { font-size: 12px; color: var(--faint); }
  .post-text { font-size: 14px; color: var(--ink); line-height: 1.55; }
  .post-media { margin-top: 10px; border-radius: 10px; overflow: hidden; }
  
  .video-thumb {
    background: linear-gradient(140deg, #1D2238, var(--navy));
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .play-btn {
    width: 48px; height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--coral) !important;
  }
  .play-btn::after {
    content: '';
    border-left: 14px solid #fff;
    border-top: 8px solid transparent;
    border-bottom: 8px solid transparent;
    margin-left: 3px;
  }
  .video-caption {
    position: absolute;
    left: 12px; right: 12px; bottom: 10px;
    background: rgba(20,24,41,.78);
    color: var(--cream);
    font-weight: 600;
    font-size: 12px;
    padding: 6px 10px;
    border-radius: 6px;
  }
  .quote-card {
    aspect-ratio: 16/10;
    padding: 22px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: linear-gradient(150deg, var(--coral), #EF8A6F) !important;
  }
  .quote-text {
    font-weight: 800;
    font-size: clamp(.95rem, 2.2vw, 1.15rem);
    color: var(--navy);
    line-height: 1.3;
  }
  .quote-attr { margin-top: 10px; font-weight: 700; font-size: 11px; color: rgba(20,24,41,.7); }
  .post-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--faint);
  }
  .reactions { display: flex; align-items: center; gap: 4px; }
  .react {
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--bg-2);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
  }
  @media (max-width: 860px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-feed { max-width: 480px; }
  }

  .want { text-align: center; }
  .want .support { margin-left: auto; margin-right: auto; max-width: 600px; }
  .want-feed-wrap { display: flex; justify-content: center; margin-bottom: 36px; }
  .want-feed { width: 100%; max-width: 480px; text-align: left; }
  .cost-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0 20px;
    align-items: center;
    margin-top: 36px;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }
  .cost-card { padding: 32px 28px; text-align: left; }
  .cost-who {
    font-weight: 700;
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--faint);
    margin-bottom: 10px;
  }
  .cost-big {
    font-weight: 800;
    font-size: clamp(1.6rem, 5vw, 2.2rem);
    letter-spacing: -.025em;
    line-height: 1.05;
    color: var(--ink);
  }
  .cost-unit { font-size: 14px; color: var(--muted); margin-top: 8px; }
  .vs-badge {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--bg-2);
    border: 1px solid var(--border);
    font-weight: 800;
    font-size: 13px;
    color: var(--faint);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cost-section .better-way {
    color: var(--coral-dk) !important;
    text-align: center;
    margin-top: 28px;
    font-weight: 700;
    font-size: clamp(1.1rem, 3vw, 1.3rem);
  }
  @media (max-width: 600px) {
    .cost-grid { grid-template-columns: 1fr; gap: 12px; }
    .vs-badge { margin: 0 auto; }
  }

  /* Steps Section overrides */
  .steps-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 40px;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }
  .step-item {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 0 20px;
    margin-bottom: 0;
  }
  .step-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
