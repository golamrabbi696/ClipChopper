<script>
  const form = document.getElementById('quick-contact-form') as HTMLFormElement;
  const success = document.getElementById('qc-success')!;
  const submitBtn = document.getElementById('qc-submit') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Sending…';
    submitBtn.setAttribute('disabled', 'true');
    try {
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch('https://adopted-trout-informational-crowd.trycloudflare.com/api/v1/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        success.textContent = '✓ Message sent! We\'ll be in touch soon.';
        form.reset();
      } else {
        success.textContent = 'Something went wrong. Please try again.';
        success.style.color = '#E86F50';
      }
    } catch {
      success.textContent = 'Could not connect. Please email us directly.';
      success.style.color = '#E86F50';
    } finally {
      submitBtn.textContent = 'Send message →';
      submitBtn.removeAttribute('disabled');
    }
  });
</script>
