<script>
  const API_BASE = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
    ? 'http://127.0.0.1:8000'
    : 'https://api.clipchopper.com';
  const TOKEN_KEY = 'cc_admin_token';
  const USER_KEY = 'cc_admin_user';

  // State managers
  let state = {
    bookings: { page: 1, lastPage: 1, rows: [], total: null },
    leads: { page: 1, lastPage: 1, rows: [], total: null },
    subs: { page: 1, lastPage: 1, rows: [], total: null },
    dels: { page: 1, lastPage: 1, rows: [], total: null },
    webhooks: null,
    settings: null,
    clients: []
  };

  function getToken() {
    return localStorage.getItem(TOKEN_KEY) || '';
  }

  function clearToken() {
    localStorage.removeItem(TOKEN_KEY);
    localStorage.removeItem(USER_KEY);
  }

  async function api(path, { method = 'GET', body, isMultipart = false } = {}) {
    const headers: any = { 'Accept': 'application/json' };
    const token = getToken();
    if (token) headers['Authorization'] = `Bearer ${token}`;
    if (body !== undefined && !isMultipart) headers['Content-Type'] = 'application/json';

    const res = await fetch(`${API_BASE}${path}`, {
      method,
      headers,
      body: body !== undefined ? (isMultipart ? body : JSON.stringify(body)) : undefined,
    });

    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      const msg = data?.message || `Request failed (${res.status})`;
      throw new Error(msg);
    }
    return data;
  }

  async function ensureAdminSession() {
    const token = getToken();
    if (!token) return false;
    try {
      const me = await api('/api/v1/auth/me');
      const whoEl = document.getElementById('admin-who');
      if (whoEl) whoEl.textContent = `Signed in as ${me?.email || 'admin'}`;
      return me?.role === 'admin';
    } catch {
      return false;
    }
  }

  // --- TAB Switcher ---
  function setupTabs() {
    const tabButtons = document.querySelectorAll('#admin-tab-nav .admin-nav__link');
    const panels = document.querySelectorAll('.tab-panel');
    const statsOverview = document.getElementById('stats-overview-section');
    const settingsParentBtn = document.getElementById('settings-parent-btn');
    const settingsSubmenu = document.getElementById('settings-submenu');

    // Settings Toggle Collapse
    if (settingsParentBtn && settingsSubmenu) {
      settingsParentBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = settingsParentBtn.classList.toggle('is-open');
        settingsSubmenu.style.display = isOpen ? 'flex' : 'none';
      });
    }

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-tab');
        if (!tab) return; // Ignore settings parent button clicks for tab switching
        
        tabButtons.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');

        // Style the settings parent link if a setting sub-tab is selected
        if (btn.classList.contains('admin-nav__link--sub') && settingsParentBtn) {
          settingsParentBtn.classList.add('is-active');
        } else if (settingsParentBtn) {
          settingsParentBtn.classList.remove('is-active');
        }

        panels.forEach(p => p.classList.remove('is-active'));
        document.getElementById(`panel-${tab}`)?.classList.add('is-active');

        // Stats overview only on Bookings Tab
        if (statsOverview) {
          statsOverview.style.display = tab === 'bookings' ? 'grid' : 'none';
        }
      });
    });

    // Auto-open settings submenu if initial active tab is under it
    const activeTabBtn = document.querySelector('#admin-tab-nav .admin-nav__link.is-active');
    if (activeTabBtn?.classList.contains('admin-nav__link--sub') && settingsParentBtn && settingsSubmenu) {
      settingsParentBtn.classList.add('is-open');
      settingsParentBtn.classList.add('is-active');
      settingsSubmenu.style.display = 'flex';
    }
  }

  // --- Utility functions ---
  function showStatus(text, elementId, isError = false) {
    const el = document.getElementById(elementId);
    if (!el) return;
    el.textContent = text;
    el.classList.toggle('is-error', isError);
    setTimeout(() => {
      el.textContent = '';
      el.classList.remove('is-error');
    }, 4000);
  }

  function fmtDate(iso) {
    if (!iso) return '—';
    const d = new Date(iso);
    return Number.isNaN(d.getTime()) ? '—' : d.toLocaleString();
  }

  // --- Data Loaders ---
  async function loadBookings(page = 1) {
    const search = (document.getElementById('book-search') as HTMLInputElement)?.value || '';
    const status = (document.getElementById('book-status') as HTMLSelectElement)?.value || '';
    const tbody = document.getElementById('bookings-body');
    const pageIndicator = document.getElementById('book-page');
    if (!tbody) return;

    try {
      const query = new URLSearchParams({ page: String(page), search, status }).toString();
      const payload = await api(`/api/v1/admin/bookings?${query}`);
      
      state.bookings.rows = payload.data || [];
      state.bookings.page = payload.current_page || 1;
      state.bookings.lastPage = payload.last_page || 1;
      state.bookings.total = payload.total || 0;

      if (state.bookings.rows.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="admin-help text-center">No bookings found.</td></tr>`;
      } else {
        tbody.innerHTML = state.bookings.rows.map(b => {
          const lead = b.lead || {};
          const scheduledAt = b.call_scheduled_at ? new Date(b.call_scheduled_at).toLocaleString() : '—';
          return `
            <tr>
              <td><strong>${lead.name || '—'}</strong></td>
              <td>${lead.email || '—'}</td>
              <td>${scheduledAt} (${b.call_timezone || 'UTC'})</td>
              <td><span class="admin-pill">${b.plan || '—'}</span></td>
              <td>
                <select class="status-select booking-status-select" data-id="${b.id}">
                  <option value="pending" ${b.status === 'pending' ? 'selected' : ''}>Pending</option>
                  <option value="confirmed" ${b.status === 'confirmed' ? 'selected' : ''}>Confirmed</option>
                  <option value="completed" ${b.status === 'completed' ? 'selected' : ''}>Completed</option>
                  <option value="cancelled" ${b.status === 'cancelled' ? 'selected' : ''}>Cancelled</option>
                </select>
              </td>
              <td>${fmtDate(b.created_at)}</td>
            </tr>
          `;
        }).join('');

        // Bind status changes
        document.querySelectorAll('.booking-status-select').forEach(select => {
          select.addEventListener('change', async (e) => {
            const id = (e.target as HTMLSelectElement).getAttribute('data-id');
            const newStatus = (e.target as HTMLSelectElement).value;
            try {
              await api(`/api/v1/admin/bookings/${id}`, {
                method: 'PATCH',
                body: { status: newStatus }
              });
              showStatus('Booking status updated.', 'bookings-status');
              loadBookings(state.bookings.page);
            } catch (err: any) {
              showStatus(err.message || 'Failed to update.', 'bookings-status', true);
            }
          });
        });
      }

      if (pageIndicator) pageIndicator.textContent = `Page ${state.bookings.page} / ${state.bookings.lastPage}`;
      updateStats();
    } catch (err: any) {
      tbody.innerHTML = `<tr><td colspan="6" class="admin-help text-center text-error">Failed to load bookings.</td></tr>`;
    }
  }

  async function loadLeads(page = 1) {
    const search = (document.getElementById('lead-search') as HTMLInputElement)?.value || '';
    const status = (document.getElementById('lead-status') as HTMLSelectElement)?.value || '';
    const tbody = document.getElementById('leads-body');
    const pageIndicator = document.getElementById('lead-page');
    if (!tbody) return;

    try {
      const query = new URLSearchParams({ page: String(page), search, status }).toString();
      const payload = await api(`/api/v1/admin/leads?${query}`);
      
      state.leads.rows = payload.data || [];
      state.leads.page = payload.current_page || 1;
      state.leads.lastPage = payload.last_page || 1;
      state.leads.total = payload.total || 0;

      if (state.leads.rows.length === 0) {
        tbody.innerHTML = `<tr><td colspan="7" class="admin-help text-center">No leads found.</td></tr>`;
      } else {
        tbody.innerHTML = state.leads.rows.map(l => {
          return `
            <tr>
              <td><strong>${l.name || '—'}</strong></td>
              <td>${l.company || '—'}</td>
              <td>${l.email || '—'}</td>
              <td><span class="admin-pill">${l.plan || '—'}</span></td>
              <td class="admin-help" style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${l.message || ''}">${l.message || '—'}</td>
              <td>
                <select class="status-select lead-status-select" data-id="${l.id}">
                  <option value="new" ${l.status === 'new' ? 'selected' : ''}>New</option>
                  <option value="contacted" ${l.status === 'contacted' ? 'selected' : ''}>Contacted</option>
                  <option value="booked" ${l.status === 'booked' ? 'selected' : ''}>Booked</option>
                  <option value="lost" ${l.status === 'lost' ? 'selected' : ''}>Lost</option>
                </select>
              </td>
              <td>${fmtDate(l.created_at)}</td>
            </tr>
          `;
        }).join('');

        // Bind status changes
        document.querySelectorAll('.lead-status-select').forEach(select => {
          select.addEventListener('change', async (e) => {
            const id = (e.target as HTMLSelectElement).getAttribute('data-id');
            const newStatus = (e.target as HTMLSelectElement).value;
            try {
              await api(`/api/v1/admin/leads/${id}`, {
                method: 'PATCH',
                body: { status: newStatus }
              });
              showStatus('Lead status updated.', 'leads-status');
              loadLeads(state.leads.page);
            } catch (err: any) {
              showStatus(err.message || 'Failed to update lead.', 'leads-status', true);
            }
          });
        });
      }

      if (pageIndicator) pageIndicator.textContent = `Page ${state.leads.page} / ${state.leads.lastPage}`;
    } catch (err: any) {
      tbody.innerHTML = `<tr><td colspan="7" class="admin-help text-center text-error">Failed to load leads.</td></tr>`;
    }
  }

  async function loadSubscribers(page = 1) {
    const tbody = document.getElementById('subscribers-body');
    const pageIndicator = document.getElementById('sub-page');
    if (!tbody) return;

    try {
      const payload = await api(`/api/v1/admin/subscribers?page=${page}`);
      
      state.subs.rows = payload.data || [];
      state.subs.page = payload.current_page || 1;
      state.subs.lastPage = payload.last_page || 1;
      state.subs.total = payload.total || 0;

      if (state.subs.rows.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" class="admin-help text-center">No subscribers found.</td></tr>`;
      } else {
        tbody.innerHTML = state.subs.rows.map(s => {
          const status = s.unsubscribed_at ? 'Unsubscribed' : 'Active';
          const tagClass = s.unsubscribed_at ? 'admin-tag--cancelled' : 'admin-tag--confirmed';
          return `
            <tr>
              <td><strong>${s.email || '—'}</strong></td>
              <td>${s.name || '—'}</td>
              <td>${fmtDate(s.subscribed_at)}</td>
              <td>${s.unsubscribed_at ? fmtDate(s.unsubscribed_at) : '—'}</td>
              <td><span class="admin-tag ${tagClass}">${status}</span></td>
            </tr>
          `;
        }).join('');
      }

      if (pageIndicator) pageIndicator.textContent = `Page ${state.subs.page} / ${state.subs.lastPage}`;
    } catch (err: any) {
      tbody.innerHTML = `<tr><td colspan="5" class="admin-help text-center text-error">Failed to load subscribers.</td></tr>`;
    }
  }

  async function loadClients() {
    const clientSelect = document.getElementById('del-client') as HTMLSelectElement;
    if (!clientSelect) return;
    try {
      const clients = await api('/api/v1/admin/clients');
      state.clients = clients || [];
      
      // Populate select dropdown
      clientSelect.innerHTML = '<option value="">Select client...</option>' + 
        state.clients.map(c => `<option value="${c.id}">${c.name} (${c.email})</option>`).join('');
    } catch (err: any) {
      console.error('Failed to load clients list.', err);
    }
  }

  async function loadDeliverables(page = 1) {
    const tbody = document.getElementById('deliverables-body');
    const pageIndicator = document.getElementById('del-page');
    if (!tbody) return;

    try {
      const payload = await api(`/api/v1/admin/deliverables?page=${page}`);
      
      state.dels.rows = payload.data || [];
      state.dels.page = payload.current_page || 1;
      state.dels.lastPage = payload.last_page || 1;
      state.dels.total = payload.total || 0;

      if (state.dels.rows.length === 0) {
        tbody.innerHTML = `<tr><td colspan="6" class="admin-help text-center">No deliverables found.</td></tr>`;
      } else {
        tbody.innerHTML = state.dels.rows.map(d => {
          const user = d.user || {};
          const icon = d.type === 'video' ? '🎬' : (d.type === 'post' ? '✍️' : '🖼️');
          return `
            <tr>
              <td><strong>${user.name || '—'}</strong></td>
              <td>${d.month || '—'}</td>
              <td><span class="admin-pill">${icon} ${d.type}</span></td>
              <td><a href="${d.file_url}" target="_blank" class="back-link" style="font-weight:700">${d.title || 'Link'}</a></td>
              <td><span class="admin-tag admin-tag--pending">${d.status}</span></td>
              <td>
                <button class="delete-btn deliverable-delete-btn" data-id="${d.id}" title="Delete deliverable">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                </button>
              </td>
            </tr>
          `;
        }).join('');

        // Bind delete action
        document.querySelectorAll('.deliverable-delete-btn').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            const target = e.currentTarget as HTMLButtonElement;
            const id = target.getAttribute('data-id');
            if (confirm('Are you sure you want to delete this deliverable?')) {
              try {
                await api(`/api/v1/admin/deliverables/${id}`, { method: 'DELETE' });
                showStatus('Deliverable deleted.', 'deliverables-list-status');
                loadDeliverables(state.dels.page);
              } catch (err: any) {
                showStatus(err.message || 'Failed to delete.', 'deliverables-list-status', true);
              }
            }
          });
        });
      }

      if (pageIndicator) pageIndicator.textContent = `Page ${state.dels.page} / ${state.dels.lastPage}`;
    } catch (err: any) {
      tbody.innerHTML = `<tr><td colspan="6" class="admin-help text-center text-error">Failed to load deliverables list.</td></tr>`;
    }
  }

  async function loadWebhooks() {
    try {
      const s = await api('/api/v1/admin/webhooks');
      state.webhooks = s;

      const whDiscordEnabled = document.getElementById('wh-discord-enabled') as HTMLInputElement;
      const whDiscordUrl = document.getElementById('wh-discord-url') as HTMLInputElement;
      const whTelegramEnabled = document.getElementById('wh-telegram-enabled') as HTMLInputElement;
      const whTelegramToken = document.getElementById('wh-telegram-token') as HTMLInputElement;
      const whTelegramChat = document.getElementById('wh-telegram-chat') as HTMLInputElement;

      if (whDiscordEnabled) whDiscordEnabled.checked = !!s.discord_enabled;
      if (whDiscordUrl) whDiscordUrl.value = s.discord_webhook_url || '';
      if (whTelegramEnabled) whTelegramEnabled.checked = !!s.telegram_enabled;
      if (whTelegramToken) whTelegramToken.value = s.telegram_bot_token || '';
      if (whTelegramChat) whTelegramChat.value = s.telegram_chat_id || '';

      updateStats();
    } catch (err) {
      console.error('Failed to load webhook settings.', err);
    }
  }

  async function loadSiteSettings() {
    try {
      const settings = await api('/api/v1/settings');
      state.settings = settings;

      const brandLogoMark = document.getElementById('brand-logo-mark') as HTMLInputElement;
      const brandLogoType = document.getElementById('brand-logo-type') as HTMLInputElement;
      const brandTextRadio = document.getElementById('brand-logo-text-radio') as HTMLInputElement;
      const brandImageRadio = document.getElementById('brand-logo-image-radio') as HTMLInputElement;
      const textGroup = document.getElementById('branding-text-options');
      const imageGroup = document.getElementById('branding-image-options');
      const previewContainer = document.getElementById('logo-preview-container');

      if (brandLogoMark) brandLogoMark.value = settings.logo_text_mark || 'CC';
      if (brandLogoType) brandLogoType.value = settings.logo_text_type || 'CLIPCHOPPER';
      
      if (settings.logo_type === 'image') {
        if (brandImageRadio) brandImageRadio.checked = true;
        textGroup?.classList.add('hidden');
        imageGroup?.classList.remove('hidden');
      } else {
        if (brandTextRadio) brandTextRadio.checked = true;
        textGroup?.classList.remove('hidden');
        imageGroup?.classList.add('hidden');
      }

      if (previewContainer) {
        if (settings.logo_image_url) {
          previewContainer.innerHTML = `<img src="${settings.logo_image_url}" alt="Logo Preview" />`;
        } else {
          previewContainer.innerHTML = `<span class="placeholder-text">No image uploaded</span>`;
        }
      }

      updateLogoInHeader(settings);
    } catch (err) {
      console.error('Failed to load branding settings.', err);
    }
  }

  function updateLogoInHeader(settings) {
    const badge = document.getElementById('dash-logomark');
    const title = document.getElementById('dash-logotype');
    const brand = document.querySelector('.admin-brand');

    if (!brand) return;

    if (settings.logo_type === 'image' && settings.logo_image_url) {
      brand.innerHTML = `
        <img src="${settings.logo_image_url}" alt="ClipChopper" style="height: 40px; max-width: 180px; object-fit: contain; border-radius: 6px;" />
        <div class="admin-titleblock" style="margin-left: 12px">
          <div class="admin-kicker">Admin Portal</div>
          <div class="admin-subtitle" id="admin-who">Signed in</div>
        </div>
      `;
      ensureAdminSession();
    } else {
      brand.innerHTML = `
        <div class="admin-badge" id="dash-logomark">${settings.logo_text_mark || 'CC'}</div>
        <div class="admin-titleblock">
          <div class="admin-kicker">Admin Portal</div>
          <div class="admin-title" id="dash-logotype">${settings.logo_text_type || 'CLIPCHOPPER'}</div>
          <div class="admin-subtitle" id="admin-who">Signed in</div>
        </div>
      `;
      ensureAdminSession();
    }
  }

  function updateStats() {
    const showing = state.bookings.rows?.length || 0;
    const total = state.bookings.total;

    const statBookingsTotal = document.getElementById('stat-bookings-total');
    const statBookingsMeta = document.getElementById('stat-bookings-meta');
    const statBookingsPill = document.getElementById('stat-bookings-pill');
    const statNextWhen = document.getElementById('stat-next-when');
    const statNextWho = document.getElementById('stat-next-who');
    const statNextPill = document.getElementById('stat-next-pill');
    const statWebhooksPill = document.getElementById('stat-webhooks-pill');
    const statWebhooksValue = document.getElementById('stat-webhooks-value');
    const statWebhooksMeta = document.getElementById('stat-webhooks-meta');

    if (statBookingsTotal) statBookingsTotal.textContent = total !== null ? String(total) : String(showing);
    if (statBookingsMeta) statBookingsMeta.textContent = total !== null ? `Total bookings • Showing ${showing}` : `Showing ${showing}`;
    if (statBookingsPill) statBookingsPill.textContent = `Page ${state.bookings.page} / ${state.bookings.lastPage}`;

    // Find next upcoming meeting
    const now = new Date();
    const upcoming = (state.bookings.rows || [])
      .map(b => {
        let when: Date | null = null;
        if (b.call_scheduled_at) {
          when = new Date(b.call_scheduled_at);
        } else {
          const dateStr = b.call_date ? b.call_date.slice(0, 10) : '';
          const timeStr = b.call_time || '';
          if (dateStr) {
            when = timeStr ? new Date(`${dateStr}T${timeStr}`) : new Date(dateStr);
          }
        }
        return { b, when };
      })
      .filter(x => x.when && !isNaN(x.when.getTime()) && x.when.getTime() >= now.getTime() && x.b.status === 'confirmed')
      .sort((a, b) => (a.when as Date).getTime() - (b.when as Date).getTime())[0];

    if (upcoming?.b && upcoming?.when) {
      const lead = upcoming.b.lead || {};
      if (statNextWhen) statNextWhen.textContent = upcoming.when.toLocaleString();
      if (statNextWho) statNextWho.textContent = `${lead.name || '—'} • ${lead.email || '—'}`;
      if (statNextPill) statNextPill.textContent = 'Confirmed';
    } else {
      if (statNextWhen) statNextWhen.textContent = '—';
      if (statNextWho) statNextWho.textContent = 'No upcoming confirmed meetings';
      if (statNextPill) statNextPill.textContent = '—';
    }

    const discordOn = !!state.webhooks?.discord_enabled;
    const telegramOn = !!state.webhooks?.telegram_enabled;
    const enabledCount = (discordOn ? 1 : 0) + (telegramOn ? 1 : 0);
    const webhooksKnown = state.webhooks !== null;

    if (statWebhooksPill) statWebhooksPill.textContent = webhooksKnown ? (enabledCount ? `${enabledCount} enabled` : 'Disabled') : '-';
    if (statWebhooksValue) statWebhooksValue.textContent = webhooksKnown ? (enabledCount ? 'Active' : 'Off') : '-';
    if (statWebhooksMeta) statWebhooksMeta.textContent = webhooksKnown ? `Discord: ${discordOn ? 'On' : 'Off'} | Telegram: ${telegramOn ? 'On' : 'Off'}` : 'Unable to load settings.';
  }

  // --- Form Handlers ---
  function setupForms() {
    const webhooksForm = document.getElementById('webhooks-form');
    const brandingForm = document.getElementById('branding-form');
    const deliverableForm = document.getElementById('deliverable-upload-form');

    // Webhooks Submit
    webhooksForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const statusEl = 'webhooks-status';
      showStatus('Saving...', statusEl);
      
      const whDiscordEnabled = (document.getElementById('wh-discord-enabled') as HTMLInputElement).checked;
      const whDiscordUrl = (document.getElementById('wh-discord-url') as HTMLInputElement).value;
      const whTelegramEnabled = (document.getElementById('wh-telegram-enabled') as HTMLInputElement).checked;
      const whTelegramToken = (document.getElementById('wh-telegram-token') as HTMLInputElement).value;
      const whTelegramChat = (document.getElementById('wh-telegram-chat') as HTMLInputElement).value;

      try {
        await api('/api/v1/admin/webhooks', {
          method: 'PUT',
          body: {
            discord_enabled: whDiscordEnabled,
            discord_webhook_url: whDiscordUrl || null,
            telegram_enabled: whTelegramEnabled,
            telegram_bot_token: whTelegramToken || null,
            telegram_chat_id: whTelegramChat || null
          }
        });
        showStatus('Saved webhook configurations.', statusEl);
        await loadWebhooks();
      } catch (err: any) {
        showStatus(err.message || 'Failed to save.', statusEl, true);
      }
    });

    // Deliverable Upload Submit
    deliverableForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const statusEl = 'deliverables-upload-status';
      showStatus('Uploading deliverable...', statusEl);

      const data = Object.fromEntries(new FormData(deliverableForm as HTMLFormElement));
      try {
        await api('/api/v1/admin/deliverables', {
          method: 'POST',
          body: data
        });
        showStatus('Deliverable delivered successfully!', statusEl);
        deliverableForm.reset();
        loadDeliverables(1);
      } catch (err: any) {
        showStatus(err.message || 'Failed to deliver content.', statusEl, true);
      }
    });

    // Logo Display Type toggler
    const textRadio = document.getElementById('brand-logo-text-radio');
    const imageRadio = document.getElementById('brand-logo-image-radio');
    const textGroup = document.getElementById('branding-text-options');
    const imageGroup = document.getElementById('branding-image-options');

    textRadio?.addEventListener('change', () => {
      textGroup?.classList.remove('hidden');
      imageGroup?.classList.add('hidden');
    });

    imageRadio?.addEventListener('change', () => {
      textGroup?.classList.add('hidden');
      imageGroup?.classList.remove('hidden');
    });

    // Branding Submit
    brandingForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const statusEl = 'branding-status';
      showStatus('Applying changes...', statusEl);

      const formData = new FormData(brandingForm as HTMLFormElement);
      try {
        const payload = await api('/api/v1/admin/settings', {
          method: 'POST',
          body: formData,
          isMultipart: true
        });
        showStatus(payload.message || 'Settings applied successfully.', statusEl);
        await loadSiteSettings();
      } catch (err: any) {
        showStatus(err.message || 'Failed to apply branding settings.', statusEl, true);
      }
    });

    // Admin Create Submit
    const createForm = document.getElementById('admin-create-form') as HTMLFormElement;
    createForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const statusEl = 'admin-create-status';
      showStatus('Creating account...', statusEl);
      
      const submitBtn = document.getElementById('ac-submit') as HTMLButtonElement;
      if (submitBtn) {
        submitBtn.textContent = 'Creating…';
        submitBtn.setAttribute('disabled', 'true');
      }

      const data = Object.fromEntries(new FormData(createForm));
      try {
        await api('/api/v1/admin/admins', {
          method: 'POST',
          body: data
        });
        showStatus('✓ Admin account created successfully!', statusEl);
        createForm.reset();
      } catch (err: any) {
        showStatus(err.message || 'Failed to create admin account.', statusEl, true);
      } finally {
        if (submitBtn) {
          submitBtn.textContent = 'Create Admin Account';
          submitBtn.removeAttribute('disabled');
        }
      }
    });
  }

  // --- Pagination & Search Filters setup ---
  function setupFiltersAndPagination() {
    // Bookings Filters
    document.getElementById('book-search')?.addEventListener('input', () => loadBookings(1));
    document.getElementById('book-status')?.addEventListener('change', () => loadBookings(1));
    document.getElementById('book-prev')?.addEventListener('click', () => {
      if (state.bookings.page > 1) loadBookings(state.bookings.page - 1);
    });
    document.getElementById('book-next')?.addEventListener('click', () => {
      if (state.bookings.page < state.bookings.lastPage) loadBookings(state.bookings.page + 1);
    });

    // Leads Filters
    document.getElementById('lead-search')?.addEventListener('input', () => loadLeads(1));
    document.getElementById('lead-status')?.addEventListener('change', () => loadLeads(1));
    document.getElementById('lead-prev')?.addEventListener('click', () => {
      if (state.leads.page > 1) loadLeads(state.leads.page - 1);
    });
    document.getElementById('lead-next')?.addEventListener('click', () => {
      if (state.leads.page < state.leads.lastPage) loadLeads(state.leads.page + 1);
    });

    // Subscribers Pagination
    document.getElementById('sub-prev')?.addEventListener('click', () => {
      if (state.subs.page > 1) loadSubscribers(state.subs.page - 1);
    });
    document.getElementById('sub-next')?.addEventListener('click', () => {
      if (state.subs.page < state.subs.lastPage) loadSubscribers(state.subs.page + 1);
    });

    // Deliverables Pagination
    document.getElementById('del-prev')?.addEventListener('click', () => {
      if (state.dels.page > 1) loadDeliverables(state.dels.page - 1);
    });
    document.getElementById('del-next')?.addEventListener('click', () => {
      if (state.dels.page < state.dels.lastPage) loadDeliverables(state.dels.page + 1);
    });

    // Logout & Refresh Buttons
    document.getElementById('admin-logout')?.addEventListener('click', () => {
      clearToken();
      window.location.href = '/admin/login';
    });
    document.getElementById('admin-refresh')?.addEventListener('click', async () => {
      const activeTab = document.querySelector('#admin-tab-nav .admin-nav__link.is-active')?.getAttribute('data-tab');
      if (activeTab === 'bookings') await loadBookings(state.bookings.page);
      if (activeTab === 'leads') await loadLeads(state.leads.page);
      if (activeTab === 'subscribers') await loadSubscribers(state.subs.page);
      if (activeTab === 'deliverables') {
        await loadClients();
        await loadDeliverables(state.dels.page);
      }
      if (activeTab === 'notifications') await loadWebhooks();
      if (activeTab === 'branding') await loadSiteSettings();
    });
  }

  // --- Initialization ---
  async function loadInitialData() {
    setupTabs();
    setupFiltersAndPagination();
    setupForms();

    // Fire off async loads
    await Promise.all([
      loadBookings(1),
      loadLeads(1),
      loadSubscribers(1),
      loadClients(),
      loadDeliverables(1),
      loadWebhooks(),
      loadSiteSettings()
    ]);
  }

  (async () => {
    const ok = await ensureAdminSession();
    if (!ok) {
      clearToken();
      window.location.href = '/admin/login';
      return;
    }
    await loadInitialData();
  })();
</script>
